# Local development — personal stage overrides
# Copy to .env.local and adjust. .env.local is gitignored.

# Your personal stage name (used by sst dev). Defaults to your username.
# STAGE=robert

# AWS profile used locally (SST uses this unless CI=true).
# AWS_PROFILE=itinn-bot

# AWS region (must match GitHub environment var).
# AWS_REGION=eu-west-1
