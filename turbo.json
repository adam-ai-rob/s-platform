{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["tsconfig.base.json", "biome.json"],
  "tasks": {
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": ["src/**/*.ts", "tsconfig.json", "package.json"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^typecheck"],
      "inputs": ["src/**/*.ts", "package.json"],
      "outputs": []
    },
    "test:integration": {
      "dependsOn": ["^typecheck"],
      "inputs": [
        "src/**/*.ts",
        "core/src/**/*.ts",
        "functions/src/**/*.ts",
        "tests/integration/**/*.ts",
        "package.json"
      ],
      "outputs": []
    },
    "test:contract": {
      "dependsOn": ["^typecheck"],
      "inputs": [
        "src/**/*.ts",
        "core/src/**/*.ts",
        "functions/src/**/*.ts",
        "tests/contract/**/*.ts",
        "../*/contracts/*.json",
        "package.json"
      ],
      "outputs": []
    },
    "test:coverage": {
      "dependsOn": ["^typecheck"],
      "inputs": ["src/**/*.ts", "package.json"],
      "outputs": ["coverage/**"]
    },
    "test:coverage:html": {
      "dependsOn": ["^typecheck"],
      "inputs": ["src/**/*.ts", "package.json"],
      "outputs": ["coverage/**"]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "tsconfig.json", "package.json"],
      "outputs": ["dist/**"]
    }
  }
}
