{
  "openapi": "3.1.0",
  "info": {
    "title": "s-user HTTP API",
    "version": "1.0.0"
  },
  "components": {
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "UserSearchHit": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "avatarUrl": {
            "type": "string"
          },
          "createdAtMs": {
            "type": "number"
          },
          "updatedAtMs": {
            "type": "number"
          },
          "highlights": {
            "type": "object",
            "additionalProperties": {
              "nullable": true
            }
          }
        },
        "required": ["id", "firstName", "lastName", "displayName", "createdAtMs", "updatedAtMs"]
      },
      "UserSearchListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserSearchHit"
            }
          },
          "meta": {
            "type": "object",
            "properties": {
              "page": {
                "type": "integer"
              },
              "perPage": {
                "type": "integer"
              },
              "found": {
                "type": "integer"
              },
              "outOf": {
                "type": "integer"
              },
              "searchTimeMs": {
                "type": "integer"
              },
              "nextCursor": {
                "type": "string"
              },
              "facets": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "field": {
                      "type": "string"
                    },
                    "counts": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "value": {
                            "type": "string"
                          },
                          "count": {
                            "type": "integer"
                          }
                        },
                        "required": ["value", "count"]
                      }
                    }
                  },
                  "required": ["field", "counts"]
                }
              }
            },
            "required": ["page", "perPage", "found", "outOf", "searchTimeMs"]
          },
          "metadata": {
            "type": "object",
            "properties": {
              "nextToken": {
                "type": "string"
              }
            }
          }
        },
        "required": ["data", "meta"]
      },
      "LegacyUserSearchResponse": {
        "type": "object",
        "properties": {
          "hits": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserSearchHit"
            }
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserSearchHit"
            }
          },
          "meta": {
            "type": "object",
            "properties": {
              "page": {
                "type": "integer"
              },
              "perPage": {
                "type": "integer"
              },
              "found": {
                "type": "integer"
              },
              "outOf": {
                "type": "integer"
              },
              "searchTimeMs": {
                "type": "integer"
              },
              "nextCursor": {
                "type": "string"
              },
              "facets": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "field": {
                      "type": "string"
                    },
                    "counts": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "value": {
                            "type": "string"
                          },
                          "count": {
                            "type": "integer"
                          }
                        },
                        "required": ["value", "count"]
                      }
                    }
                  },
                  "required": ["field", "counts"]
                }
              }
            },
            "required": ["page", "perPage", "found", "outOf", "searchTimeMs"]
          },
          "metadata": {
            "type": "object",
            "properties": {
              "nextToken": {
                "type": "string"
              }
            }
          },
          "page": {
            "type": "integer"
          },
          "per_page": {
            "type": "integer"
          },
          "found": {
            "type": "integer"
          },
          "out_of": {
            "type": "integer"
          },
          "search_time_ms": {
            "type": "integer"
          },
          "next_cursor": {
            "type": "string"
          }
        },
        "required": [
          "hits",
          "data",
          "meta",
          "page",
          "per_page",
          "found",
          "out_of",
          "search_time_ms"
        ]
      },
      "UserProfile": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "avatarUrl": {
            "type": "string"
          },
          "preferences": {
            "type": "object",
            "additionalProperties": {
              "nullable": true
            }
          },
          "metadata": {
            "type": "object",
            "additionalProperties": {
              "nullable": true
            }
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "userId",
          "firstName",
          "lastName",
          "preferences",
          "metadata",
          "createdAt",
          "updatedAt"
        ]
      },
      "ProfileResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/UserProfile"
          }
        },
        "required": ["data"]
      },
      "UpdateProfileBody": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string",
            "maxLength": 100
          },
          "lastName": {
            "type": "string",
            "maxLength": 100
          },
          "avatarUrl": {
            "type": "string",
            "nullable": true,
            "format": "uri"
          },
          "preferences": {
            "type": "object",
            "additionalProperties": {
              "nullable": true
            }
          },
          "metadata": {
            "type": "object",
            "additionalProperties": {
              "nullable": true
            }
          }
        }
      }
    },
    "parameters": {}
  },
  "paths": {
    "/user/admin/users": {
      "get": {
        "tags": ["User Admin"],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Search user profiles",
        "description": "Typesense-backed list over user profiles. Requires `user_superadmin`.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "q",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "filter_by",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "sort_by",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "facet_by",
            "in": "query"
          },
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true
            },
            "required": false,
            "name": "page",
            "in": "query"
          },
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true,
              "maximum": 100
            },
            "required": false,
            "name": "per_page",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "cursor",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserSearchListResponse"
                }
              }
            }
          },
          "403": {
            "description": "Missing permission"
          }
        }
      }
    },
    "/user/search": {
      "get": {
        "tags": ["User Legacy"],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Search user profiles (deprecated)",
        "description": "Deprecated legacy list shape. Use `GET /user/admin/users` and read `{ data, meta }`.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "q",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "filter_by",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "sort_by",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "facet_by",
            "in": "query"
          },
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true
            },
            "required": false,
            "name": "page",
            "in": "query"
          },
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true,
              "maximum": 100
            },
            "required": false,
            "name": "per_page",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "cursor",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LegacyUserSearchResponse"
                }
              }
            }
          }
        }
      }
    },
    "/user/user/users/me": {
      "get": {
        "tags": ["User"],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Get the caller's profile",
        "responses": {
          "200": {
            "description": "Profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfileResponse"
                }
              }
            }
          },
          "404": {
            "description": "Profile not yet provisioned"
          }
        }
      },
      "patch": {
        "tags": ["User"],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Update the caller's profile (partial)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProfileBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfileResponse"
                }
              }
            }
          },
          "404": {
            "description": "Profile not found"
          }
        }
      }
    },
    "/user/admin/users/{id}": {
      "get": {
        "tags": ["User Admin"],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Get any user's profile",
        "description": "Requires `user_superadmin`.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfileResponse"
                }
              }
            }
          },
          "403": {
            "description": "Missing permission"
          },
          "404": {
            "description": "Profile not found"
          }
        }
      }
    },
    "/user/me": {
      "get": {
        "tags": ["User Legacy"],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Get the caller's profile (deprecated)",
        "responses": {
          "200": {
            "description": "Profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfileResponse"
                }
              }
            }
          },
          "404": {
            "description": "Profile not yet provisioned"
          }
        }
      },
      "patch": {
        "tags": ["User Legacy"],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Update the caller's profile (deprecated)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProfileBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfileResponse"
                }
              }
            }
          },
          "404": {
            "description": "Profile not found"
          }
        }
      }
    },
    "/user/{id}": {
      "get": {
        "tags": ["User Legacy"],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Get any user's profile (deprecated)",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfileResponse"
                }
              }
            }
          },
          "404": {
            "description": "Profile not found"
          }
        }
      }
    }
  }
}
