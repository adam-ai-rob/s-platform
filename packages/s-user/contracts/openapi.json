{
  "openapi": "3.1.0",
  "info": {
    "title": "s-user HTTP API",
    "version": "1.0.0"
  },
  "components": {
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "UserProfile": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "avatarUrl": {
            "type": "string"
          },
          "preferences": {
            "type": "object",
            "additionalProperties": {
              "nullable": true
            }
          },
          "metadata": {
            "type": "object",
            "additionalProperties": {
              "nullable": true
            }
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "userId",
          "firstName",
          "lastName",
          "preferences",
          "metadata",
          "createdAt",
          "updatedAt"
        ]
      },
      "ProfileResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/UserProfile"
          }
        },
        "required": ["data"]
      },
      "UpdateProfileBody": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string",
            "maxLength": 100
          },
          "lastName": {
            "type": "string",
            "maxLength": 100
          },
          "avatarUrl": {
            "type": "string",
            "nullable": true,
            "format": "uri"
          },
          "preferences": {
            "type": "object",
            "additionalProperties": {
              "nullable": true
            }
          },
          "metadata": {
            "type": "object",
            "additionalProperties": {
              "nullable": true
            }
          }
        }
      }
    },
    "parameters": {}
  },
  "paths": {
    "/user/me": {
      "get": {
        "tags": ["User"],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Get the caller's profile",
        "responses": {
          "200": {
            "description": "Profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfileResponse"
                }
              }
            }
          },
          "404": {
            "description": "Profile not yet provisioned"
          }
        }
      },
      "patch": {
        "tags": ["User"],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Update the caller's profile (partial)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProfileBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfileResponse"
                }
              }
            }
          },
          "404": {
            "description": "Profile not found"
          }
        }
      }
    },
    "/user/{id}": {
      "get": {
        "tags": ["User"],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Get any user's profile",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfileResponse"
                }
              }
            }
          },
          "404": {
            "description": "Profile not found"
          }
        }
      }
    }
  }
}
