{
  "openapi": "3.1.0",
  "info": {
    "title": "s-group HTTP API",
    "version": "1.0.0"
  },
  "components": {
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Membership": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "groupId": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "rel": {
            "type": "string",
            "enum": ["owner", "manual", "domain", "group"]
          },
          "status": {
            "type": "string",
            "enum": ["active", "pending", "rejected"]
          },
          "addedBy": {
            "type": "string"
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": ["id", "groupId", "userId", "rel", "status", "createdAt", "updatedAt"]
      },
      "MembershipListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Membership"
            }
          }
        },
        "required": ["data"]
      },
      "Group": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["company", "team", "building"]
          },
          "emailDomainNames": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "automaticUserAssignment": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "emailDomainNames",
          "automaticUserAssignment",
          "createdAt",
          "updatedAt"
        ]
      },
      "GroupResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/Group"
          }
        },
        "required": ["data"]
      },
      "CreateGroupBody": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "description": {
            "type": "string",
            "maxLength": 1000
          },
          "type": {
            "type": "string",
            "enum": ["company", "team", "building"]
          },
          "emailDomainNames": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "automaticUserAssignment": {
            "type": "boolean",
            "default": true
          }
        },
        "required": ["name"]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/group/user/me/groups": {
      "get": {
        "tags": ["Group"],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "List caller's group memberships",
        "description": "Returns the authenticated caller's active group memberships in a `{ data }` envelope.",
        "responses": {
          "200": {
            "description": "Memberships",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MembershipListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token"
          }
        }
      }
    },
    "/group/admin/groups": {
      "post": {
        "tags": ["Group Admin"],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Create a group",
        "description": "Creates a group with a unique name and optional domain-matching configuration. Requires a bearer token with `group_admin`.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateGroupBody"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GroupResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token"
          },
          "403": {
            "description": "Missing group_admin permission"
          },
          "409": {
            "description": "Name exists"
          }
        }
      }
    },
    "/group/admin/groups/{id}": {
      "get": {
        "tags": ["Group Admin"],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Get a group",
        "description": "Returns one group by id. Requires a bearer token with `group_admin`.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Group",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GroupResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token"
          },
          "403": {
            "description": "Missing group_admin permission"
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "delete": {
        "tags": ["Group Admin"],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Delete a group",
        "description": "Deletes a group by id. Requires a bearer token with `group_admin`; returns 404 when the group does not exist.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted"
          },
          "401": {
            "description": "Missing or invalid bearer token"
          },
          "403": {
            "description": "Missing group_admin permission"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/group/admin/groups/{id}/users/{userId}": {
      "post": {
        "tags": ["Group Admin"],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Add a user to a group (rel: manual)",
        "description": "Creates a manual membership between the group and user. Requires `group_admin`; returns 409 if the manual membership already exists.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "id",
            "in": "path"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "userId",
            "in": "path"
          }
        ],
        "responses": {
          "204": {
            "description": "Added"
          },
          "401": {
            "description": "Missing or invalid bearer token"
          },
          "403": {
            "description": "Missing group_admin permission"
          },
          "404": {
            "description": "Group not found"
          },
          "409": {
            "description": "Already a member"
          }
        }
      },
      "delete": {
        "tags": ["Group Admin"],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Remove a user from a group (rel: manual)",
        "description": "Removes an existing manual membership between the group and user. Requires `group_admin`; returns 404 when the membership does not exist.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "id",
            "in": "path"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "userId",
            "in": "path"
          }
        ],
        "responses": {
          "204": {
            "description": "Removed"
          },
          "401": {
            "description": "Missing or invalid bearer token"
          },
          "403": {
            "description": "Missing group_admin permission"
          },
          "404": {
            "description": "Membership not found"
          }
        }
      }
    }
  }
}
