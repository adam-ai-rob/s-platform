{
  "openapi": "3.1.0",
  "info": {
    "title": "s-authn HTTP API",
    "version": "1.0.0"
  },
  "components": {
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ChangePasswordBody": {
        "type": "object",
        "properties": {
          "currentPassword": {
            "type": "string"
          },
          "newPassword": {
            "type": "string",
            "minLength": 8,
            "maxLength": 128
          }
        },
        "required": [
          "currentPassword",
          "newPassword"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/authn/auth/sessions:revoke": {
      "post": {
        "tags": [
          "Session"
        ],
        "summary": "Revoke refresh tokens (AIP-136 custom action)",
        "description": "Revoke refresh tokens for the caller. The public URL is `POST /authn/user/sessions:revoke`.\nThis uses the AIP-136 workaround where colon-prefixed actions are rewritten to `/_actions/{verb}`.",
        "security": [
          {
            "Bearer": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "tokenIds": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "all": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Tokens revoked"
          },
          "400": {
            "description": "Invalid request"
          }
        }
      }
    },
    "/authn/user/users/me/password": {
      "patch": {
        "tags": [
          "User"
        ],
        "summary": "Change the caller's password",
        "security": [
          {
            "Bearer": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangePasswordBody"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Password changed"
          },
          "401": {
            "description": "Current password incorrect"
          }
        }
      }
    },
    "/authn/user/users/{id}/password": {
      "patch": {
        "tags": [
          "User Admin"
        ],
        "summary": "Change any user's password (admin)",
        "description": "Requires `user_superadmin` permission.",
        "security": [
          {
            "Bearer": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "newPassword": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "newPassword"
                ]
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Password changed"
          },
          "403": {
            "description": "Missing user_superadmin permission"
          },
          "404": {
            "description": "User not found"
          }
        }
      }
    },
    "/authn/auth/me/logout": {
      "post": {
        "tags": [
          "User (DEPRECATED)"
        ],
        "summary": "Revoke the caller's refresh token (DEPRECATED)",
        "description": "Legacy endpoint. Deprecated and will be removed in the next release.\nUse `POST /authn/user/sessions:revoke` instead.",
        "security": [
          {
            "Bearer": []
          }
        ],
        "responses": {
          "204": {
            "description": "Logged out"
          }
        }
      }
    },
    "/authn/user/me/password": {
      "patch": {
        "tags": [
          "User (DEPRECATED)"
        ],
        "summary": "Change the caller's password (DEPRECATED)",
        "description": "Legacy endpoint. Deprecated and will be removed in the next release.\nUse `PATCH /authn/user/users/me/password` instead.",
        "security": [
          {
            "Bearer": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangePasswordBody"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Password changed"
          },
          "401": {
            "description": "Current password incorrect"
          }
        }
      }
    }
  }
}
