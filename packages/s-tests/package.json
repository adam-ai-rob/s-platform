{
  "name": "@s/tests",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "End-to-end journey tests. Run against a deployed stage (dev/test/prod/pr-N).",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test src/smoke.test.ts --timeout 60000",
    "test:e2e": "bun test src --timeout 60000",
    "test:dev": "STAGE=dev bun test src --timeout 60000",
    "test:test": "STAGE=test bun test src --timeout 60000",
    "test:prod": "STAGE=prod bun test src/smoke.test.ts --timeout 60000"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.650.0",
    "@aws-sdk/client-ssm": "^3.650.0",
    "@aws-sdk/lib-dynamodb": "^3.650.0",
    "@s/shared": "workspace:*",
    "ulid": "^2.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "bun-types": "latest"
  }
}
